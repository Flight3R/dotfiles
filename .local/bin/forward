#!/bin/zsh

session_name="NETWORK"
if [[ -z $(sudo tmux list-sessions | grep $session_name) ]]
then
    sudo tmux new-session -s $session_name \
        -n manage zsh -c "iftop -i eth1
                           sudo -u user zsh" \; \
            split-window -h zsh -c "watch -n 2 --color nmcli --colors yes con
                                     sudo -u user zsh" \; \
            split-window -v zsh -c "set -x
                                     sysctl -w net.ipv4.ip_forward=1
                                     iptables -t nat -A POSTROUTING -o eth2 -j MASQUERADE
                                     iptables -t nat -A POSTROUTING -o wlan0 -j MASQUERADE
                                     set +x
                                     zsh" \; \
        select-pane -t 0 \;  split-window -v zsh -c "top
                                                      sudo -u user zsh" \; \
        select-pane -t 3

        if [[ $? -eq 0 ]]; then
            LOG_FILE=$(/home/user/scripts/get-log-file)
            echo $(date) -- forward started >> $LOG_FILE
        fi
else
    echo "$session_name session already exists! Attaching..."
    sudo tmux attach-session -t $session_name
fi
